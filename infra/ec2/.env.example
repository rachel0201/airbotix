# /opt/airbotix/secrets/.env (chmod 600, owner ubuntu)
# Loaded by both systemd (airbotix-backend.service) AND docker-compose.
# Source values from AWS Secrets Manager: aws secretsmanager get-secret-value --secret-id /airbotix/prod/<key>

# --- App ---
PORT=3000
CORS_ORIGIN=https://app.airbotix.ai,https://teacher.airbotix.ai

# --- Docker / ECR ---
ECR_REGISTRY=123456789012.dkr.ecr.ap-southeast-2.amazonaws.com
IMAGE_TAG=latest

# --- Database (Neon ap-southeast-2) ---
DATABASE_URL=postgresql://USER:PASS@HOST.neon.tech/airbotix?sslmode=require

# --- Auth / JWT ---
JWT_SECRET=
JWT_PREVIOUS_SECRET=
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC_ADULT=2592000
JWT_REFRESH_TTL_SEC_KID=86400
JWT_REFRESH_TTL_SEC_CLASS=14400

# --- OTP ---
OTP_TTL_SEC=600
OTP_MAX_ATTEMPTS=5
OTP_HASH_SALT=

# --- SendGrid ---
SENDGRID_API_KEY=
SENDGRID_FROM=no-reply@airbotix.ai
SENDGRID_OTP_TEMPLATE_PARENT=
SENDGRID_OTP_TEMPLATE_TEACHER=

# --- Cookies ---
COOKIE_DOMAIN=.airbotix.ai
COOKIE_SECURE=true

# --- AWS (use IAM role on the instance — leave these empty in prod) ---
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=airbotix-artifacts-prod
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- DeepRouter ---
DEEPROUTER_BASE_URL=https://api.deeprouter.ai/v1
DEEPROUTER_API_KEY=

# --- Airwallex ---
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_WEBHOOK_SECRET=

# --- 2FA ---
TOTP_ISSUER=Airbotix
